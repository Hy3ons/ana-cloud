[Unit]
Description=vm-controller-quick-start
After=network.target

[Service]
User=root
Group=root

WorkingDirectory=/root/anacloud/vm-controller

Environment="GIN_MODE=release"
Environment="PORT=8080"

ExecStart=/root/anacloud/vm-controller/main

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
